        E3["Thread C\n[angle 3]\nInvestigate"]
    end

    subgraph evaluators["✅ evaluator ×3  ·  fact checking"]
        EV1["Verify A's claims\nCheck sources"]
        EV2["Verify B's claims\nCheck sources"]
        EV3["Verify C's claims\nCheck sources"]
    end

    Codebase[("📁 Sources\n(files · docs · web)")]
    Report(["📄 Final report\n(answer · confidence · sources)"])

    User --> O1
    O1 --> O2

    O2 -->|"spawn 3 in parallel"| E1
    O2 -->|"spawn 3 in parallel"| E2
    O2 -->|"spawn 3 in parallel"| E3

    E1 <-->|"read · search"| Codebase
    E2 <-->|"read · search"| Codebase
    E3 <-->|"read · search"| Codebase

    E1 -->|"findings ready"| EV1
    E2 -->|"findings ready"| EV2
    E3 -->|"findings ready"| EV3

    EV1 <-->|"verify claims"| Codebase
    EV2 <-->|"verify claims"| Codebase
    EV3 <-->|"verify claims"| Codebase

    EV1 -->|"OK / NOK"| E1
    EV2 -->|"OK / NOK"| E2
    EV3 -->|"OK / NOK"| E3

    E1 -->|"findings + verdict"| O3
    E2 -->|"findings + verdict"| O3
    E3 -->|"findings + verdict"| O3

    O3 --> O4
    O4 --> Report

